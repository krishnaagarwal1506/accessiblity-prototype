{
  "manifest_version": 3,
  "name": "Accessibility Checker",
  "version": "1.0.0",
  "description": "Detects and highlights web accessibility issues based on WCAG guidelines.",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "devtools_page": "src/devtools/init.html"
}
